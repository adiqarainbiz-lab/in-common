PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=incommon
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
QR_JWT_EXPIRES_IN=90s

# OTP (set to 'console' for dev, 'sms' for production)
OTP_DELIVERY=console
