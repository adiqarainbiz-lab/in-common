PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=incommon
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
QR_JWT_EXPIRES_IN=90s

# OTP delivery: 'console' for dev, 'sms' for production
OTP_DELIVERY=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Admin app (VITE_API_URL in apps/admin/.env)
# Create first admin: node scripts/create-admin.js <email> <password> [name]
